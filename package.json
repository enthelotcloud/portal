{
    "$schema": "https://www.schemastore.org/package.json",

    "name": "fileflow",

    "version": "1.0.0",

    "description": "Broadcast Transfer System",

    "author": "Enthelot Cloud",

    "main": "electron/main.cjs",

    "private": true,

    "type": "module",

    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "electron": "electron .",
        "socket": "nodemon server.cjs",
        "dist": "electron-builder"
    },

    "dependencies": {
        "@tailwindcss/vite": "^4.1.11",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.0.1",
        "cors": "^2.8.5",
        "express": "^5.1.0",
        "laravel-vite-plugin": "^3.1",
        "multer": "^2.0.2",
        "socket.io": "^4.8.1",
        "socket.io-client": "^4.8.1",
        "tailwindcss": "^4.0.7",
        "vite": "^8.0.0"
    },

    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    },

    "devDependencies": {
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "nodemon": "^3.1.10"
    },

    "build": {
        "appId": "com.fileflow.transfer",

        "productName": "FileFlow",

        "asar": true,

        "win": {
            "target": "nsis",

            "sign": false
        },

        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
